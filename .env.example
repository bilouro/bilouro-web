# Copy to .env and fill in values for local dev
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=dev-only-change-in-prod-please-please-please
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://bilouro:bilouro@localhost:5432/bilouro

# Wagtail admin URL (used in emails, etc.)
WAGTAILADMIN_BASE_URL=http://localhost:8000

# Email — local dev prints to console
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=hello@bilouro.com

# studio.bilouro.com — booking-form notifications land here
STUDIO_BOOKING_NOTIFY_EMAIL=consulting@bilouro.com

# In prod (/etc/bilouro.env) also add studio to:
#   ALLOWED_HOSTS=...,studio.bilouro.com
#   CSRF_TRUSTED_ORIGINS=...,https://studio.bilouro.com

# AWS (only needed in prod; safe to leave blank locally)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=eu-west-1
# AWS_SES_REGION_NAME=eu-west-1
